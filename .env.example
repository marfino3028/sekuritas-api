APP_NAME="Sekuritas Demo API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sekuritas_demo
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET=
JWT_TTL=1440
JWT_REFRESH_TTL=20160

# ============================================
# Frontend & CMS URLs (CORS)
# ============================================
FRONTEND_URL=http://localhost:3000
CMS_URL=http://localhost:3001

# ============================================
# S-INVEST Integration (Mock)
# ============================================
S_INVEST_BASE_URL=https://mock-sinvest.api/v1
S_INVEST_API_KEY=DEMO_KEY_12345
S_INVEST_PARTICIPANT_CODE=SEK001

# ============================================
# Payment Gateway (Mock)
# ============================================
PAYMENT_GATEWAY_URL=https://mock-payment.api/v1
PAYMENT_GATEWAY_KEY=DEMO_PAYMENT_KEY
PAYMENT_GATEWAY_SECRET=DEMO_PAYMENT_SECRET
PAYMENT_EXPIRY_HOURS=24

# ============================================
# Storage
# ============================================
STORAGE_DRIVER=local

# ============================================
# Mail Configuration
# ============================================
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@sekuritas-demo.id"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# AWS (opsional, jika menggunakan S3)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ============================================
# eKYC (OCR KTP / Liveness / Face Match / Signature)
# ============================================
EKYC_PROVIDER=stub                 # stub | fastapi
EKYC_STORAGE_DISK=public
EKYC_SESSION_TTL=60                 # menit
EKYC_MIN_OCR=70
EKYC_MIN_LIVENESS=80
EKYC_MIN_FACE_MATCH=80
EKYC_AUTO_APPROVE=85
EKYC_MIN_REJECT=50

# FastAPI AI service (repo sekuritas-ai) — dipakai bila EKYC_PROVIDER=fastapi
EKYC_FASTAPI_URL=http://ekyc-ai:8000
EKYC_FASTAPI_KEY=
EKYC_FASTAPI_TIMEOUT=30

# Tanda tangan digital
SIGNATURE_PROVIDER=canvas          # canvas | privy
PRIVY_BASE_URL=https://api-sandbox.privy.id
PRIVY_MERCHANT_KEY=
PRIVY_ENTERPRISE_TOKEN=

# URL web depan (untuk link aktivasi di email)
FRONTEND_URL=http://localhost:3000

# ============================================================
# Payment Gateway
# ============================================================
PAYMENT_GATEWAY=mock            # mock | midtrans
PAYMENT_EXPIRY_HOURS=24
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
# XENDIT_SECRET_KEY=
# XENDIT_CALLBACK_TOKEN=

# ============================================================
# S-INVEST (KSEI) + RDN
# ============================================================
SINVEST_DRIVER=mock             # mock | ksei
SINVEST_PARTICIPANT_CODE=VS001
# SINVEST_BASE_URL=
# SINVEST_USER=
# SINVEST_SECRET=
# SINVEST_CERT_PATH=
# RDN_BANK=cimb
# RDN_BASE_URL=
# RDN_KEY=

EKYC_ENCRYPT_FILES=false

# Verifikasi NIK (demo pakai nik-parser gratis; Dukcapil resmi berbayar)
DUKCAPIL_DRIVER=nikparser        # nikparser | dukcapil
# DUKCAPIL_BASE_URL=
# DUKCAPIL_USER_ID=
# DUKCAPIL_PASSWORD=
